# Copy this file to `.env` and fill in your real values.
# `.env` is gitignored; never commit real keys.
#
# For deployed Lambda, set these via `amplify update function` or the
# Lambda console environment variables panel instead of .env.

# Your Google AI Studio API key (starts with AIza...). Grab one from
#   https://aistudio.google.com/app/apikey
# Free tier: 15 requests/minute on gemini-2.0-flash, plenty for a demo.
GEMINI_API_KEY=AIza_REPLACE_ME

# Optional: model override. Default is gemini-2.0-flash (free tier, good
# at tool use). Other options: gemini-1.5-flash, gemini-2.0-pro.
# GEMINI_MODEL=gemini-2.0-flash

# AppSync GraphQL endpoint for this environment. Find it in the
# Amplify console under API → projectclara → GraphQL endpoint, or
# in amplify/backend/amplify-meta.json under api.projectclara.output.GraphQLAPIEndpointOutput.
APPSYNC_ENDPOINT=https://REPLACE_ME.appsync-api.us-east-1.amazonaws.com/graphql

# AppSync API key. Same place: GraphQLAPIKeyOutput in amplify-meta.json.
APPSYNC_API_KEY=da2-REPLACE_ME

# The Teacher id we create in the seed script for Clara. Leave as default
# unless you change the seed script too.
CLARA_SENDER_ID=clara-ai-bot

# Port for local dev server
PORT=3000
